{
  "name": "mobilfunk-wiki",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-03-25",
  "workers_dev": false,
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "mobilfunk.wiki",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "placement": {
    "mode": "smart"
  }
}